---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- ========== HERO SECTION ========== -->
		<section id="hero" class="hero">
			<div class="hero-bg-shapes">
				<div class="hero-shape hero-shape--1"></div>
				<div class="hero-shape hero-shape--2"></div>
				<div class="hero-shape hero-shape--3"></div>
			</div>
			<div class="container">
				<div class="hero-grid">
					<div class="hero-content">
						<div class="hero-badge">
							<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0l2.2 5.5L16 6.3l-4 3.7 1 5.5L8 12.8 2.9 15.5l1-5.5-4-3.7 5.9-.8z"/></svg>
							Sınava Özel Hazırlanmış Çalışma Aracı
						</div>
						<h1 class="hero-title">
							BKÜ Sınavına <br/>
							<span class="hero-title--highlight">Hazırlığın</span> <br/>
							Tek Adresi
						</h1>
						<p class="hero-subtitle">
							Mevzuat, soru bankası, deneme sınavları, flashcard tekrar sistemi ve daha fazlası — sınav hazırlığınızı tek bir uygulamadan, planlı ve sistemli şekilde yönetin.
						</p>
						<div class="store-buttons">
							<a href="#" class="store-btn" id="hero-appstore" aria-label="App Store'dan İndir">
								<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
								<span class="store-btn__label">
									<span class="store-btn__small">Şimdi İndir</span>
									<span class="store-btn__big">App Store</span>
								</span>
							</a>
							<a href="#" class="store-btn" id="hero-gplay" aria-label="Google Play'den İndir">
								<svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 1.33-2.922 1.691-2.07-2.07 2.69-2.951zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
								<span class="store-btn__label">
									<span class="store-btn__small">Şimdi İndir</span>
									<span class="store-btn__big">Google Play</span>
								</span>
							</a>
						</div>
						<div class="hero-stats">
							<div class="hero-stat">
								<span class="hero-stat__number">9+</span>
								<span class="hero-stat__label">Çalışma Modülü</span>
							</div>
							<div class="hero-stat-divider"></div>
							<div class="hero-stat">
								<span class="hero-stat__number">1000+</span>
								<span class="hero-stat__label">Soru İçeriği</span>
							</div>
							<div class="hero-stat-divider"></div>
							<div class="hero-stat">
								<span class="hero-stat__number">BKÜ</span>
								<span class="hero-stat__label">Sınava Özel</span>
							</div>
						</div>
					</div>
					<div class="hero-visual">
						<div class="hero-phone">
							<div class="phone-frame">
								<div class="phone-notch"></div>
								<div class="phone-screen">
									<div class="mock-app">
										<div class="mock-header">
											<div class="mock-greeting">Hoş geldin</div>
											<div class="mock-title">BKÜBTS Pro</div>
										</div>
										<div class="mock-progress-card">
											<div class="mock-progress-label">Genel İlerleme</div>
											<div class="mock-progress-bar"><div class="mock-progress-fill" style="width: 68%"></div></div>
											<div class="mock-progress-text">%68 Tamamlandı</div>
										</div>
										<div class="mock-modules">
											<div class="mock-module">
												<div class="mock-module-icon" style="background:#E8F5EE;color:#1B5E3B;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg></div>
												<div class="mock-module-info">
													<div class="mock-module-name">Mevzuat</div>
													<div class="mock-module-sub">12 bölüm</div>
												</div>
												<div class="mock-module-badge">%82</div>
											</div>
											<div class="mock-module">
												<div class="mock-module-icon" style="background:#FEF3C7;color:#D97706;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg></div>
												<div class="mock-module-info">
													<div class="mock-module-name">Soru Bankası</div>
													<div class="mock-module-sub">450 soru</div>
												</div>
												<div class="mock-module-badge">%54</div>
											</div>
											<div class="mock-module">
												<div class="mock-module-icon" style="background:#EDE9FE;color:#7C3AED;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg></div>
												<div class="mock-module-info">
													<div class="mock-module-name">Deneme Sınavı</div>
													<div class="mock-module-sub">8 deneme</div>
												</div>
												<div class="mock-module-badge">%35</div>
											</div>
											<div class="mock-module">
												<div class="mock-module-icon" style="background:#FCE7F3;color:#DB2777;"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg></div>
												<div class="mock-module-info">
													<div class="mock-module-name">Flashcard</div>
													<div class="mock-module-sub">180 kart</div>
												</div>
												<div class="mock-module-badge">%71</div>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
						<div class="hero-float-card hero-float-card--1">
							<div class="float-card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg></div>
							<div>
								<div class="float-card-title">Günlük Hedef</div>
								<div class="float-card-text">20 soru çözüldü</div>
							</div>
						</div>
						<div class="hero-float-card hero-float-card--2">
							<div class="float-card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg></div>
							<div>
								<div class="float-card-title">Başarı Oranı</div>
								<div class="float-card-text">%87 doğruluk</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ========== TRUST / POSITIONING ========== -->
		<section id="guven" class="section trust-section">
			<div class="container">
				<div class="trust-grid">
					<div class="trust-card animate-on-scroll">
						<div class="trust-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg></div>
						<h3>Sınava Özel</h3>
						<p>Yalnızca BKÜ / BKUBTS sınavına odaklı, sınav konularına göre hazırlanmış içerikler</p>
					</div>
					<div class="trust-card animate-on-scroll">
						<div class="trust-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div>
						<h3>Tek Merkezde</h3>
						<p>Mevzuat, soru çözümü, tekrar ve takip araçları tek bir uygulamada</p>
					</div>
					<div class="trust-card animate-on-scroll">
						<div class="trust-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg></div>
						<h3>Her Yerde Çalış</h3>
						<p>iOS ve Android destekli, istediğiniz an istediğiniz yerden çalışma imkanı</p>
					</div>
					<div class="trust-card animate-on-scroll">
						<div class="trust-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--color-primary)"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg></div>
						<h3>İlerlemeni Gör</h3>
						<p>Çalışma sürecinizi ölçün, eksiklerinizi keşfedin, stratejik ilerleyin</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ========== FEATURES SECTION ========== -->
		<section id="ozellikler" class="section section--alt">
			<div class="container">
				<div class="section-header">
					<div class="section-badge">
						<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0l2.2 5.5L16 6.3l-4 3.7 1 5.5L8 12.8 2.9 15.5l1-5.5-4-3.7 5.9-.8z"/></svg>
						Güçlü Özellikler
					</div>
					<h2 class="section-title">Sınav Hazırlığınız İçin<br/>İhtiyacınız Olan Her Şey</h2>
					<p class="section-subtitle">Her modül, sınava hazırlık sürecinizin farklı bir aşamasını desteklemek için tasarlanmıştır. Öğrenin, çözün, tekrar edin ve ilerleyişinizi takip edin.</p>
				</div>

				<!-- Feature Spotlight 1: Mevzuat -->
				<div class="feature-spotlight animate-on-scroll">
					<div class="feature-spotlight__content">
						<div class="feature-spotlight__badge">01</div>
						<h3 class="feature-spotlight__title">Mevzuat Çalışma Modülü</h3>
						<p class="feature-spotlight__desc">Karmaşık mevzuat metinlerini daha erişilebilir ve anlaşılır hale getiren çalışma alanı. Bölüm bölüm, madde madde ilerleyin ve mevzuatlar arasında kaybolmadan odaklı çalışın.</p>
						<ul class="feature-spotlight__list">
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Mevzuatları tek yerde toplu şekilde görüntüleyin
							</li>
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Bölüm ve madde bazlı ilerleme takibi
							</li>
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Sadeleştirilmiş çalışma deneyimi
							</li>
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Odaklı ve akıcı çalışma ortamı
							</li>
						</ul>
					</div>
					<div class="feature-spotlight__visual">
						<div class="feature-phone">
							<div class="phone-frame phone-frame--sm">
								<div class="phone-notch"></div>
								<div class="phone-screen">
									<div class="mock-mevzuat">
										<div class="mock-mevzuat-header"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect></svg> Mevzuat</div>
										<div class="mock-mevzuat-item done">
											<span class="mock-check">✓</span>
											<div>
												<div class="mock-mevzuat-title">Bitki Koruma Ürünleri Yönetmeliği</div>
												<div class="mock-mevzuat-sub">42 madde · Tamamlandı</div>
											</div>
										</div>
										<div class="mock-mevzuat-item done">
											<span class="mock-check">✓</span>
											<div>
												<div class="mock-mevzuat-title">Zirai Karantina Yönetmeliği</div>
												<div class="mock-mevzuat-sub">28 madde · Tamamlandı</div>
											</div>
										</div>
										<div class="mock-mevzuat-item active">
											<span class="mock-check active">▶</span>
											<div>
												<div class="mock-mevzuat-title">Tohumculuk Kanunu</div>
												<div class="mock-mevzuat-sub">35 madde · Devam ediyor</div>
											</div>
										</div>
										<div class="mock-mevzuat-item">
											<span class="mock-check empty"></span>
											<div>
												<div class="mock-mevzuat-title">Gıda Kanunu</div>
												<div class="mock-mevzuat-sub">18 madde</div>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Feature Spotlight 2: Soru Bankası -->
				<div class="feature-spotlight feature-spotlight--reverse animate-on-scroll">
					<div class="feature-spotlight__content">
						<div class="feature-spotlight__badge">02</div>
						<h3 class="feature-spotlight__title">Soru Bankası</h3>
						<p class="feature-spotlight__desc">Rastgele çalışmak yerine kontrollü ve hedefli soru çözümü yapın. Konu bazlı pratik yaparak eksik olduğunuz alanları hızla fark edin ve bilginizi pekiştirin.</p>
						<ul class="feature-spotlight__list">
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Konu bazlı pratik yapma
							</li>
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Eksik olunan alanları hızlı fark etme
							</li>
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Tekrar çözerek bilgiyi pekiştirme
							</li>
							<li>
								<svg width="18" height="18" viewBox="0 0 16 16" fill="var(--color-primary)"><circle cx="8" cy="8" r="8"/><path d="M5 8l2 2 4-4" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
								Sınava yönelik odaklı alıştırma
							</li>
						</ul>
					</div>
					<div class="feature-spotlight__visual">
						<div class="feature-phone">
							<div class="phone-frame phone-frame--sm">
								<div class="phone-notch"></div>
								<div class="phone-screen">
									<img src="/mockup-quiz.png" alt="Soru Bankası ekran görüntüsü" class="mock-screenshot" />
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Feature Grid: Small Features -->
				<div class="features-grid">
					<!-- Deneme Sınavları -->
					<div class="feature-card animate-on-scroll">
						<div class="feature-card__icon" style="background: #FEF3C7; color: #D97706;">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
						</div>
						<h4 class="feature-card__title">Deneme Sınavları</h4>
						<p class="feature-card__desc">Gerçek sınav deneyimine yakın çalışma ortamı. Zaman yönetimi pratiği yapın, performansınızı ölçün ve sınav öncesi hazırbulunuşluğunuzu test edin.</p>
						<ul class="feature-card__tags">
							<li>Zaman Yönetimi</li>
							<li>Performans Ölçümü</li>
						</ul>
					</div>

					<!-- Flashcard -->
					<div class="feature-card animate-on-scroll">
						<div class="feature-card__icon" style="background: #EDE9FE; color: #7C3AED;">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="3"/><path d="M12 4v16M2 12h20"/></svg>
						</div>
						<h4 class="feature-card__title">Flashcard Tekrar Sistemi</h4>
						<p class="feature-card__desc">Çalıştığınızı unutmamak için akıllı tekrar. Kısa tekrarlarla kalıcı öğrenme sağlayın, yoğun bilgi yükünü yönetilebilir hale getirin.</p>
						<ul class="feature-card__tags">
							<li>Akıllı Tekrar</li>
							<li>Kalıcı Öğrenme</li>
						</ul>
					</div>

					<!-- Yanlışlarım -->
					<div class="feature-card animate-on-scroll">
						<div class="feature-card__icon" style="background: #FCE7F3; color: #DB2777;">
							<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 9v4M12 17h.01"/><circle cx="12" cy="12" r="10"/></svg>
						</div>
						<h4 class="feature-card__title">Yanlışlarım</h4>
						<p class="feature-card__desc">Kişisel koçluk hissi. Hatalı çözdüğünüz soruları yeniden çalışın, zayıf noktalarınızı görün ve aynı hataları tekrar etmeyin.</p>
						<ul class="feature-card__tags">
							<li>Hata Analizi</li>
							<li>Stratejik Çalışma</li>
						</ul>
					</div>

					<!-- Favorilerim -->
					<div class="feature-card animate-on-scroll">
						<div class="feature-card__icon" style="background: #FEE2E2; color: #EF4444;">
